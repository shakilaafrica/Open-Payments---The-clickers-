# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# URL this backend is reachable at (used to build the GNAP callback URL)
BACKEND_URL=http://localhost:3001

# URL the frontend is served at (used for CORS and post-callback redirect)
FRONTEND_URL=http://localhost:5173

# ─── Open Payments Credentials ────────────────────────────────────────────────
# Obtain these from https://wallet.interledger-test.dev
#
# Your wallet address (the "client" wallet that signs requests)
OP_WALLET_ADDRESS=https://ilp.interledger-test.dev/YOUR_HANDLE

# UUID of the key you uploaded to your wallet's Developer Keys section
OP_KEY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Path to the Ed25519 private key .pem file (relative to backend/)
# Generate with: openssl genpkey -algorithm Ed25519 -out private.key
OP_PRIVATE_KEY_PATH=./private.key

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./openremit.db

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWTs. Change this to a long random string in production.
JWT_SECRET=changeme
