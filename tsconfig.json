{
  "compilerOptions": {
    "target": "ES2022",
    // CommonJS + classic resolution: @libsql/client only publishes ESM types
    // under the newer Node16 resolution, which breaks `npm run build`.
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
